-- ========== ФУНКЦИИ ==========
local function UpdateSelectedCount()
    local count = 0
    for _ in pairs(Settings.SelectedCases) do count = count + 1 end
    CountLabel.Text = "📋 Выбрано: " .. count .. " кейсов"
end

local function IsCaseSelected(caseName)
    return Settings.SelectedCases[caseName] == true
end

local function RefreshCasesList(searchText)
    for _, child in pairs(Scroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    for _, caseName in ipairs(AllCases) do
        if searchText == "" or string.find(string.lower(caseName), string.lower(searchText)) then
            local btn = Instance.new("TextButton")
            btn.Parent = Scroll
            btn.BackgroundColor3 = IsCaseSelected(caseName) and Colors.Primary or Colors.BtnColor
            btn.BorderSizePixel = 0
            btn.Size = UDim2.new(1, -8, 0, 28)
            btn.Font = Enum.Font.Gotham
            btn.Text = (IsCaseSelected(caseName) and "✅ " or "☐ ") .. caseName
            btn.TextColor3 = IsCaseSelected(caseName) and Color3.fromRGB(0, 0, 0) or Colors.Primary
            btn.TextSize = 10
            AddNeonGlow(btn, Colors.Primary)
            
            local btnCorner = Instance.new("UICorner")
            btnCorner.CornerRadius = UDim.new(0, 5)
            btnCorner.Parent = btn
            
            btn.MouseButton1Click:Connect(function()
                if IsCaseSelected(caseName) then
                    Settings.SelectedCases[caseName] = nil
                else
                    Settings.SelectedCases[caseName] = true
                end
                RefreshCasesList(SearchBox.Text)
                UpdateSelectedCount()
            end)
        end
    end
end

local function UpdateLuckTimer()
    if LuckActive then
        local remaining = LuckEndTime - os.time()
        if remaining <= 0 then
            LuckActive = false
            LuckIcon.Visible = false
            LuckStatus.Text = "⚡ Не активна"
            LuckStatus.TextColor3 = Color3.fromRGB(150, 150, 150)
        else
            local minutes = math.floor(remaining / 60)
            local seconds = remaining % 60
            LuckIconTimerLabel.Text = string.format("%d:%02d", minutes, seconds)
        end
    end
end

local function UpdateSaveTimer()
    if SaveActive then
        local remaining = SaveEndTime - os.time()
        if remaining <= 0 then
            SaveActive = false
            SaveIcon.Visible = false
            SaveStatus.Text = "⚡ Не активен"
            SaveStatus.TextColor3 = Color3.fromRGB(150, 150, 150)
        else
            local minutes = math.floor(remaining / 60)
            local seconds = remaining % 60
            SaveIconTimerLabel.Text = string.format("%d:%02d", minutes, seconds)
        end
    end
end

local function FarmLoop()
    while Farming do
        pcall(function()
            local Events = ReplicatedStorage:FindFirstChild("Events")
            if Events then
                local OpenCase = Events:FindFirstChild("OpenCase")
                
                for caseName, _ in pairs(Settings.SelectedCases) do
                    if OpenCase then
                        for i = 1, Settings.OpenAmount do
                            OpenCase:InvokeServer(caseName, 1)
                            task.wait(0.03)
                        end
                    end
                    task.wait(Settings.FarmDelay)
                end
                
                if AutoSell then
                    local Inventory = Events:FindFirstChild("Inventory")
                    if Inventory then
                        Inventory:FireServer("Sell", "ALL")
                    end
                end
                
                if AutoBuy then
                    local BuyCase = Events:FindFirstChild("BuyCase")
                    if BuyCase then
                        for caseName, _ in pairs(Settings.SelectedCases) do
                            BuyCase:InvokeServer(caseName, 1)
                            task.wait(Settings.AutoBuySpeed or 1)
                        end
                    end
                end
            end
        end)
        task.wait(Settings.FarmDelay)
    end
end

-- ========== СОБЫТИЯ ==========
MiniButton.MouseButton1Click:Connect(function()
    MainFrame.Visible = true
    MiniFrame.Visible = false
end)

MinimizeBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = false
    MiniFrame.Visible = true
end)

CasesBtn.MouseButton1Click:Connect(function()
    CasesFrame.Visible = true
    RefreshCasesList("")
    UpdateSelectedCount()
end)

CloseCases.MouseButton1Click:Connect(function()
    CasesFrame.Visible = false
end)

SaveCases.MouseButton1Click:Connect(function()
    SaveSettings()
    CasesFrame.Visible = false
    UpdateSelectedCount()
end)

SelectAll.MouseButton1Click:Connect(function()
    for _, caseName in ipairs(AllCases) do
        Settings.SelectedCases[caseName] = true
    end
    RefreshCasesList(SearchBox.Text)
    UpdateSelectedCount()
end)

DeselectAll.MouseButton1Click:Connect(function()
    Settings.SelectedCases = {}
    RefreshCasesList(SearchBox.Text)
    UpdateSelectedCount()
end)

SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
    RefreshCasesList(SearchBox.Text)
end)

SellBtn.MouseButton1Click:Connect(function()
    AutoSell = not AutoSell
    SellStatus.Text = AutoSell and "🛒 ПРОДАЖА: ВКЛ" or "🛒 ПРОДАЖА: ВЫКЛ"
    SellStatus.TextColor3 = AutoSell and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 100, 100)
end)

BuyBtn.MouseButton1Click:Connect(function()
    AutoBuy = not AutoBuy
    BuyStatus.Text = AutoBuy and "🛍️ ПОКУПКА: ВКЛ" or "🛍️ ПОКУПКА: ВЫКЛ"
    BuyStatus.TextColor3 = AutoBuy and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 100, 100)
end)

LuckMainBtn.MouseButton1Click:Connect(function()
    LuckFrame.Visible = true
end)

CloseLuck.MouseButton1Click:Connect(function()
    LuckFrame.Visible = false
end)

StartLuckBtn.MouseButton1Click:Connect(function()
    local timeMin = tonumber(LuckTimeBox.Text) or 5
    if timeMin < 1 then timeMin = 1 end
    if timeMin > 60 then timeMin = 60 end
    
    LuckActive = true
    LuckEndTime = os.time() + (timeMin * 60)
    LuckIcon.Visible = true
    LuckIconMultLabel.Text = "x" .. LuckMultiplier
    LuckStatus.Text = "🍀 АКТИВНА x" .. LuckMultiplier .. " | " .. timeMin .. " мин"
    LuckStatus.TextColor3 = Colors.Primary
    LuckFrame.Visible = false
end)

SaveMainBtn.MouseButton1Click:Connect(function()
    SaveFrame.Visible = true
end)

CloseSave.MouseButton1Click:Connect(function()
    SaveFrame.Visible = false
end)

StartSaveBtn.MouseButton1Click:Connect(function()
    local timeMin = tonumber(SaveTimeBox.Text) or 5
    if timeMin < 1 then timeMin = 1 end
    if timeMin > 60 then timeMin = 60 end
    
    SaveActive = true
    SaveEndTime = os.time() + (timeMin * 60)
    SaveIcon.Visible = true
    SaveStatus.Text = "💾 АКТИВЕН | " .. timeMin .. " мин"
    SaveStatus.TextColor3 = Colors.Primary
    SaveFrame.Visible = false
end)

LuckIconClose.MouseButton1Click:Connect(function()
    LuckActive = false
    LuckIcon.Visible = false
    LuckStatus.Text = "⚡ Не активна"
    LuckStatus.TextColor3 = Color3.fromRGB(150, 150, 150)
end)

SaveIconClose.MouseButton1Click:Connect(function()
    SaveActive = false
    SaveIcon.Visible = false
    SaveStatus.Text = "⚡ Не активен"
    SaveStatus.TextColor3 = Color3.fromRGB(150, 150, 150)
end)

StartBtn.MouseButton1Click:Connect(function()
    if next(Settings.SelectedCases) == nil then
        FarmStatus.Text = "⚠️ ВЫБЕРИ КЕЙСЫ!"
        task.wait(2)
        FarmStatus.Text = "⚡ СТОП"
        FarmStatus.TextColor3 = Color3.fromRGB(150, 150, 150)
        return
    end
    
    Farming = not Farming
    if Farming then
        StartBtn.Text = "⏹ СТОП ФАРМ"
        FarmStatus.Text = "⚡ ФАРМ АКТИВЕН"
        FarmStatus.TextColor3 = Color3.fromRGB(0, 255, 100)
        task.spawn(FarmLoop)
    else
        StartBtn.Text = "▶ СТАРТ ФАРМ"
        FarmStatus.Text = "⚡ СТОП"
        FarmStatus.TextColor3 = Color3.fromRGB(150, 150, 150)
    end
end)

SettingsBtn.MouseButton1Click:Connect(function()
    SettingsFrame.Visible = true
end)

CloseSettings.MouseButton1Click:Connect(function()
    SettingsFrame.Visible = false
end)

AmountBox.FocusLost:Connect(function()
    local num = tonumber(AmountBox.Text)
    if num and num >= 1 and num <= 100 then
        Settings.OpenAmount = math.floor(num)
        AmountBox.Text = tostring(Settings.OpenAmount)
        SaveSettings()
    else
        AmountBox.Text = tostring(Settings.OpenAmount)
    end
end)

DelayBox.FocusLost:Connect(function()
    local num = tonumber(DelayBox.Text)
    if num and num >= 0.001 then
        Settings.FarmDelay = num
        DelayBox.Text = tostring(Settings.FarmDelay)
        SaveSettings()
    else
        DelayBox.Text = tostring(Settings.FarmDelay)
    end
end)

UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        MultList.Visible = false
    end
end)

RunService.Heartbeat:Connect(function()
    UpdateLuckTimer()
    UpdateSaveTimer()
end)

-- ========== ИНИЦИАЛИЗАЦИЯ ==========
UpdateSelectedCount()
AmountBox.Text = tostring(Settings.OpenAmount)
DelayBox.Text = tostring(Settings.FarmDelay)

print("✅ NEO CASE FARM V4 BY ROBIN LOADED!")
print("📦 УДАЧА - отдельное меню с выбором x2/x4/x6 и времени")
print("💾 СЕЙВ - отдельное меню с выбором времени, белый крестик в левом углу")
