-- НЕОНОВАЯ ОБВОДКА
local function AddNeonGlow(obj, color)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or Colors.Secondary
    stroke.Thickness = 2
    stroke.Parent = obj
end

